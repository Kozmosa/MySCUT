{
  "name": "my-scut-frontend",
  "private": true,
  "version": "0.5.0",
  "description": "A privacy-conscious cross-platform SCUT schedule and campus manual app.",
  "license": "MIT",
  "author": "Kozmosa and contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kozmosa/MySCUT.git"
  },
  "homepage": "https://github.com/Kozmosa/MySCUT#readme",
  "bugs": {
    "url": "https://github.com/Kozmosa/MySCUT/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "npm@11.18.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:todo-snapshot": "node scripts/generateTodoSnapshot.mjs",
    "build:licenses": "node scripts/generateThirdPartyLicenses.mjs",
    "typecheck": "tsc -b",
    "build:app": "node scripts/buildAppOnly.mjs",
    "release:prepare-manual": "node scripts/prepareReleaseManualSubmodule.mjs",
    "release": "node scripts/release.mjs",
    "build": "npm run build:full",
    "build:web": "node scripts/buildApp.mjs",
    "build:pwa": "node scripts/buildPwa.mjs",
    "build:full": "node scripts/buildFull.mjs",
    "build:android": "node scripts/buildAndroid.mjs",
    "build:ios": "node scripts/buildIos.mjs",
    "build:ohos-web": "node scripts/buildOhosWeb.mjs",
    "build:ohos-artifacts": "node scripts/printOhosArtifacts.mjs",
    "preview": "vite preview",
    "preview:pwa": "node scripts/previewPwa.mjs",
    "test": "vitest run",
    "check:docs": "node scripts/checkDocs.mjs",
    "audit:public-data": "node scripts/auditPublicData.mjs",
    "check": "npm run typecheck && npm test && npm run build:app && npm run check:docs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/inappbrowser": "^3.0.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/status-bar": "^8.0.1",
    "@hpcc-js/wasm-zstd": "^1.7.0",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "antd": "^5.27.0",
    "jeep-sqlite": "2.8.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "sql.js": "1.11.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.900.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "~5.6.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.1.9"
  }
}
