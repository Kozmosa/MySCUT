# ============================================
# MySCUT 构建环境变量参考
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# 或直接设置系统环境变量。
# Vite 以 `VITE_` 开头的变量会自动注入到客户端代码。
# ============================================

# ---- 构建目标平台 ----
# 可选值: web | android | ios | ohos
# 默认: web
# VITE_TARGET_PLATFORM=web

# ---- PWA 模式 ----
# 设为 1 或 true 启用 PWA Service Worker 构建
# 默认: 不启用
# VITE_PWA=1

# ---- 构建输出目录 ----
# 默认: dist/web
# VITE_OUT_DIR=dist/web

# ---- PDF.js 本地 CMap 支持 ----
# 设为 1 或 true 将 PDF 字型/编码表打包到产物中
# 默认: 不打包（使用 CDN）
# PDFJS_LOCAL_CMAP=1

# ---- Build Full 严格模式 ----
# 设为 1 或 true 使 build:full 在目标构建失败时抛出错误
# 默认: 宽松（各平台独立容错）
# BUILD_FULL_STRICT=1

# ---- Build Full 必需平台列表 ----
# 配合 BUILD_FULL_STRICT 使用，逗号分隔
# 默认: web,android,ios,ohos
# BUILD_FULL_REQUIRED=web,android,ios

# ---- Capacitor Web 目录覆盖 ----
# Native 构建脚本自动设置，一般情况下不需手动配置
# CAP_WEB_DIR=dist/android

# ---- 更新服务：版本清单 URL ----
# 自定义远程版本检查的 manifests.json 地址
# 默认: GitHub raw (Kozmosa/survive-in-scut)
# VITE_UPDATE_MANIFEST_URL=https://your-mirror.com/versions.json

# ---- 更新服务：CDN 提供商优先级 ----
# 逗号分隔，按优先级从高到低排列
# 可选值: fastgit, jsdelivr, unpkg, github, raw
# 默认: fastgit,jsdelivr,unpkg,github
# VITE_UPDATE_PROVIDER_ORDER=raw,github
